---
interface Props{
    img: string;
    title: string;
}
const {img,title,} = Astro.props;
---
<div class="flex flex-col p-5 gap-3 max-w-[340px]">
    <img class="w-full h-[600px] object-cover" src={img} alt={title}>
    <h3 class="text-black text-2xl text-center" style="font-family: 'Cormorant Garamond', serif;">{title}</h3>
</div>